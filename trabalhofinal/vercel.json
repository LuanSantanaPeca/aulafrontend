{
    "version": 2,
    "functions": {
        "api/handler.js": {
            "includeFiles": "json/bd.json"
        }
    },
    "rewrites": [
        { "source": "/alunos", "destination": "/api/handler" },
        { "source": "/alunos/:id", "destination": "/api/handler?id=:id" },
        { "source": "/cadastro", "destination": "/cadastro.html" },
        { "source": "/notas", "destination": "/notas.html" },
        { "source": "/relatorios", "destination": "/relatorios.html" },
        { "source": "/sobre", "destination": "/sobre.html" },
        { "source": "/editar", "destination": "/editar.html" },
        { "source": "/lanca_notas", "destination": "/lanca_notas.html" }
    ],
    "headers": [
        {
            "source": "/js/(.*)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/javascript; charset=utf-8"
                }
            ]
        },
        {
            "source": "/css/(.*)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/css; charset=utf-8"
                }
            ]
        }
    ]
}
